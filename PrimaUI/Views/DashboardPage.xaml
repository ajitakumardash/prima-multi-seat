<Page x:Class="PrimaUI.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:PrimaUI.ViewModels"
      Background="{StaticResource BgPrimary}">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="16"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="16"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- ── Seat Cards Row ─────────────────────────────── -->
      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Seat 1 Card -->
        <Border Grid.Column="0" Style="{StaticResource Card}">
          <StackPanel>
            <Grid>
              <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" Fill="{StaticResource Seat1}"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="SEAT 1" FontWeight="Bold" FontSize="14"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border CornerRadius="12" Padding="8,3"
                        Background="{Binding Seat1StatusBg}">
                  <TextBlock Text="{Binding Seat1Status}" FontSize="11"
                             FontWeight="SemiBold" Foreground="White"/>
                </Border>
              </StackPanel>
            </Grid>

            <Separator Background="{StaticResource Border}" Margin="0,12"/>

            <!-- Device Info -->
            <StackPanel>
              <Grid Margin="0,4">
                <TextBlock Text="🖥 Monitor" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Seat1Monitor}" HorizontalAlignment="Right"/>
              </Grid>
              <Grid Margin="0,4">
                <TextBlock Text="⌨ Keyboard" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Seat1Keyboard}" HorizontalAlignment="Right"/>
              </Grid>
              <Grid Margin="0,4">
                <TextBlock Text="🖱 Mouse" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Seat1Mouse}" HorizontalAlignment="Right"/>
              </Grid>
              <Grid Margin="0,4">
                <TextBlock Text="🔊 Audio" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Seat1Audio}" HorizontalAlignment="Right"/>
              </Grid>
            </StackPanel>

            <Separator Background="{StaticResource Border}" Margin="0,12"/>

            <StackPanel Orientation="Horizontal">
              <Button Content="▶ Start" Style="{StaticResource PrimaryButton}"
                      Background="{StaticResource Success}"
                      Command="{Binding StartSeat1Command}" Margin="0,0,8,0"/>
              <Button Content="⏹ Stop" Style="{StaticResource PrimaryButton}"
                      Background="{StaticResource Error}"
                      Command="{Binding StopSeat1Command}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Seat 2 Card -->
        <Border Grid.Column="2" Style="{StaticResource Card}">
          <StackPanel>
            <Grid>
              <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" Fill="{StaticResource Seat2}"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="SEAT 2" FontWeight="Bold" FontSize="14"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border CornerRadius="12" Padding="8,3"
                        Background="{Binding Seat2StatusBg}">
                  <TextBlock Text="{Binding Seat2Status}" FontSize="11"
                             FontWeight="SemiBold" Foreground="White"/>
                </Border>
              </StackPanel>
            </Grid>

            <Separator Background="{StaticResource Border}" Margin="0,12"/>

            <StackPanel>
              <Grid Margin="0,4">
                <TextBlock Text="🖥 Monitor" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Seat2Monitor}" HorizontalAlignment="Right"/>
              </Grid>
              <Grid Margin="0,4">
                <TextBlock Text="⌨ Keyboard" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Seat2Keyboard}" HorizontalAlignment="Right"/>
              </Grid>
              <Grid Margin="0,4">
                <TextBlock Text="🖱 Mouse" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Seat2Mouse}" HorizontalAlignment="Right"/>
              </Grid>
              <Grid Margin="0,4">
                <TextBlock Text="🔊 Audio" Foreground="{StaticResource TextSecondary}"/>
                <TextBlock Text="{Binding Seat2Audio}" HorizontalAlignment="Right"/>
              </Grid>
            </StackPanel>

            <Separator Background="{StaticResource Border}" Margin="0,12"/>

            <StackPanel Orientation="Horizontal">
              <Button Content="▶ Start" Style="{StaticResource PrimaryButton}"
                      Background="{StaticResource Success}"
                      Command="{Binding StartSeat2Command}" Margin="0,0,8,0"/>
              <Button Content="⏹ Stop" Style="{StaticResource PrimaryButton}"
                      Background="{StaticResource Error}"
                      Command="{Binding StopSeat2Command}"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── Monitor Preview ───────────────────────────── -->
      <Border Grid.Row="2" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Monitor Layout Preview" FontWeight="SemiBold" FontSize="14"/>
          <Border Height="180" Margin="0,12,0,0" Background="{StaticResource BgSecondary}"
                  CornerRadius="6" ClipToBounds="True">
            <Canvas x:Name="MonitorCanvas">
              <!-- Monitor 1 -->
              <Border Canvas.Left="40" Canvas.Top="20" Width="160" Height="120"
                      Background="#1E3A5F" BorderBrush="{StaticResource Seat1}"
                      BorderThickness="2" CornerRadius="4">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="Monitor 1" FontSize="11" TextAlignment="Center"/>
                  <TextBlock Text="Seat 1" FontSize="10"
                             Foreground="{StaticResource Seat1}" TextAlignment="Center"/>
                  <!-- Fake cursor -->
                  <TextBlock Text="▲" FontSize="14" Foreground="{StaticResource Seat1}"
                             Margin="20,10,0,0"/>
                </StackPanel>
              </Border>
              <!-- Monitor 2 -->
              <Border Canvas.Left="240" Canvas.Top="20" Width="160" Height="120"
                      Background="#1A3A2A" BorderBrush="{StaticResource Seat2}"
                      BorderThickness="2" CornerRadius="4">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="Monitor 2" FontSize="11" TextAlignment="Center"/>
                  <TextBlock Text="Seat 2" FontSize="10"
                             Foreground="{StaticResource Seat2}" TextAlignment="Center"/>
                  <TextBlock Text="▲" FontSize="14" Foreground="{StaticResource Seat2}"
                             Margin="20,10,0,0"/>
                </StackPanel>
              </Border>
            </Canvas>
          </Border>
        </StackPanel>
      </Border>

      <!-- ── System Resources ───────────────────────────── -->
      <Border Grid.Row="4" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="System Resources" FontWeight="SemiBold" FontSize="14"/>
          <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- CPU -->
            <StackPanel Grid.Column="0">
              <TextBlock Text="CPU" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
              <TextBlock Text="{Binding CpuUsage}" FontSize="22" FontWeight="Bold"
                         Foreground="{StaticResource Accent}"/>
              <ProgressBar Value="{Binding CpuValue}" Maximum="100" Height="4"
                           Background="{StaticResource BgSecondary}"
                           Foreground="{StaticResource Accent}" Margin="0,4,0,0"/>
            </StackPanel>
            <!-- RAM -->
            <StackPanel Grid.Column="2">
              <TextBlock Text="RAM" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
              <TextBlock Text="{Binding RamUsage}" FontSize="22" FontWeight="Bold"
                         Foreground="{StaticResource Success}"/>
              <ProgressBar Value="{Binding RamValue}" Maximum="100" Height="4"
                           Background="{StaticResource BgSecondary}"
                           Foreground="{StaticResource Success}" Margin="0,4,0,0"/>
            </StackPanel>
            <!-- Uptime -->
            <StackPanel Grid.Column="4">
              <TextBlock Text="Uptime" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
              <TextBlock Text="{Binding Uptime}" FontSize="22" FontWeight="Bold"
                         Foreground="{StaticResource Warning}"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

    </Grid>
  </ScrollViewer>
</Page>